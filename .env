# Environment Configuration for Monitoring Stack

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123
GF_INSTALL_PLUGINS=grafana-exploretraces-app,grafana-lokiexplore-app,grafana-metricsdrilldown-app

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sample-app
OTEL_RESOURCE_ATTRIBUTES=service.name=sample-app,service.version=1.0.0,environment=demo

# Loki Configuration
LOKI_ADDR=http://localhost:3100
LOKI_USERNAME=admin
LOKI_PASSWORD=admin123

# Prometheus Configuration
PROMETHEUS_ADDR=http://localhost:9090

# Tempo Configuration
TEMPO_ADDR=http://localhost:3200
